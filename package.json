{
  "name": "magiiss-playwright",
  "version": "1.0.0",
  "description": "Proyecto de automatización E2E para MAGIIS con Playwright + TypeScript",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "---DEV (TEST)---": "─── Desarrollo y ejecución diaria en TEST ───",
    "test:test": "cross-env ENV=test npx playwright test --project=chromium",
    "test:test:headed": "cross-env ENV=test npx playwright test --project=chromium --headed",
    "test:test:auth": "cross-env ENV=test npx playwright test tests/features/auth/specs tests/specs/api --project=chromium",
    "test:test:gateway-pg": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts",
    "test:test:gateway-pg:stripe": "cross-env ENV=test npx playwright test tests/specs/gateway-pg/stripe -c playwright.gateway-pg.config.ts",
    "test:test:gateway-pg:3ds": "cross-env ENV=test npx playwright test tests/specs/gateway-pg/stripe/recorded-3ds-happy-path.spec.ts --project=chromium --workers=1",
    "test:gateway:smoke": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts --project=smoke",
    "test:gateway:critical": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts --project=critical",
    "test:gateway:regression": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts --project=regression-web",
    "test:gateway:cargo": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts --project=cargo-a-bordo",
    "test:gateway:all": "cross-env ENV=test npx playwright test -c playwright.gateway-pg.config.ts --project=gateway-pg-chromium",
    "test:test:e2e:flow1:web": "cross-env ENV=test npx playwright test tests/e2e/flow1-carrier-driver.e2e.spec.ts --project=chromium --workers=1",
    "test:test:e2e:flow1:mobile": "cross-env ENV=test npx playwright test tests/e2e/flow1-carrier-driver.e2e.spec.ts --project=chromium --workers=1 --grep \"FLOW1-TC01-driver-app-mobile-handoff\"",
    "test:test:e2e:flow2": "cross-env ENV=test npx playwright test tests/specs/gateway-pg/stripe/e2e-mobile/apppax-personal-no3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-personal-3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-business-no3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-business-3ds.e2e.spec.ts --project=chromium --workers=1",
    "test:test:e2e:passenger": "cross-env ENV=test npx playwright test tests/specs/gateway-pg/stripe/e2e-mobile/apppax-personal-no3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-personal-3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-business-no3ds.e2e.spec.ts tests/specs/gateway-pg/stripe/e2e-mobile/apppax-business-3ds.e2e.spec.ts --project=chromium --workers=1",
    "test:test:smoke": "cross-env ENV=test npx playwright test tests/features/smoke/specs --project=chromium",
    "test:test:regression": "cross-env ENV=test npx playwright test --project=chromium",
    "test:test:ui": "cross-env ENV=test npx playwright test --ui",
    "test:test:debug": "cross-env ENV=test npx playwright test --project=chromium --debug",
    "---REGRESSION (UAT)---": "─── Regresión en UAT ───",
    "test:uat:smoke": "cross-env ENV=uat npx playwright test tests/features/smoke/specs --project=chromium",
    "test:uat:regression": "cross-env ENV=uat npx playwright test --project=chromium",
    "test:uat:headed": "cross-env ENV=uat npx playwright test --project=chromium --headed",
    "---REGRESSION (PROD)---": "─── Regresión en PROD ───",
    "test:prod:smoke": "cross-env ENV=prod npx playwright test tests/features/smoke/specs --project=chromium",
    "test:prod:smoke:headed": "cross-env ENV=prod npx playwright test tests/features/smoke/specs --project=chromium --headed",
    "test:prod:regression": "cross-env ENV=prod npx playwright test --project=chromium",
    "---UTILS---": "─── Utilidades ───",
    "pw:install": "npx playwright install --with-deps chromium",
    "test:plan": "npx playwright test --reporter=list --project=chromium --list",
    "test:ui": "npx playwright test --ui",
    "test:trace": "npx playwright show-trace",
    "appium:mcp:driver:config": "node tests/mobile/appium/scripts/generateAppiumMcpConfig.mjs driver",
    "appium:mcp:passenger:config": "node tests/mobile/appium/scripts/generateAppiumMcpConfig.mjs passenger",
    "appium:mcp:help": "node tests/mobile/appium/scripts/generateAppiumMcpConfig.mjs --help",
    "mobile:driver:home-dump": "cross-env ANDROID_DRIVER_APP_PACKAGE=com.magiis.app.test.driver pnpm exec ts-node --esm tests/mobile/appium/scripts/dump-driver-home.ts",
    "mobile:driver:login-smoke": "cross-env ANDROID_DRIVER_APP_PACKAGE=com.magiis.app.test.driver pnpm exec ts-node --esm tests/mobile/appium/scripts/driver-login-smoke.ts",
    "mobile:passenger:home-dump": "cross-env ANDROID_APP_PACKAGE=com.magiis.app.test.passenger SCREEN_LABEL=passenger-home pnpm exec ts-node --esm tests/mobile/appium/scripts/dump-current-screen.ts",
    "mobile:passenger:profile-mode-smoke": "cross-env APPIUM_SERVER_URL=http://localhost:4723 ENV=test ANDROID_PASSENGER_APP_PACKAGE=com.magiis.app.test.passenger NODE_OPTIONS=--experimental-specifier-resolution=node node --loader ts-node/esm tests/mobile/appium/scripts/passenger-home-mode-smoke.ts",
    "mobile:passenger:personal-3ds-hold-flow": "cross-env APPIUM_SERVER_URL=http://localhost:4723 ENV=test ANDROID_PASSENGER_APP_PACKAGE=com.magiis.app.test.passenger NODE_OPTIONS=--experimental-specifier-resolution=node node --loader ts-node/esm tests/mobile/appium/scripts/passenger-personal-3ds-hold-flow.ts",
    "mobile:passenger:business-no3ds-hold-flow": "cross-env APPIUM_SERVER_URL=http://localhost:4723 ENV=test ANDROID_PASSENGER_APP_PACKAGE=com.magiis.app.test.passenger NODE_OPTIONS=--experimental-specifier-resolution=node node --loader ts-node/esm tests/mobile/appium/scripts/passenger-business-no3ds-hold-flow.ts",
    "mobile:passenger:login-dump": "cross-env ANDROID_APP_PACKAGE=com.magiis.app.test.passenger pnpm exec ts-node --esm tests/mobile/appium/scripts/passenger-login-and-dump.ts",
    "appium:passenger:login-dump": "pnpm exec ts-node --esm tests/mobile/appium/scripts/passenger-login-and-dump.ts",
    "clean:evidence": "rm -rf evidence",
    "clean:all": "rm -rf evidence test-results playwright-report allure-results allure-report",
    "allure:gen": "allure generate --clean -o allure-report",
    "allure:open": "npx http-server allure-report -p 7070",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts --fix",
    "prettier:check": "npx prettier --check tests/**/*.ts",
    "prettier:fix": "npx prettier --write tests/**/*.ts",
    "check:ts": "tsc --noEmit",
    "test:login": "pnpm exec playwright test tests/features/auth/specs/login-success.e2e.spec.ts --project=chromium",
    "test:login:headed": "pnpm exec playwright test tests/features/auth/specs/login-success.e2e.spec.ts --project=chromium --headed"
  },
  "keywords": [
    "playwright",
    "e2e",
    "typescript",
    "automation",
    "qa",
    "testing",
    "magiis"
  ],
  "author": "MAGIIS QA Team",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@wdio/globals": "^9.27.0",
    "allure-commandline": "^2.33.0",
    "allure-playwright": "^3.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.0.0",
    "prettier-eslint": "^16.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "webdriverio": "^9.27.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "openai": "^6.33.0"
  }
}
