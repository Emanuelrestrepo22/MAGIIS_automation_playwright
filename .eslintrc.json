{
	"env": {
		"browser": true,
		"es2021": true,
		"node": true
	},
	"extends": [
		"eslint:recommended",
		"plugin:@typescript-eslint/recommended",
		"plugin:prettier/recommended"
	],
	"parser": "@typescript-eslint/parser",
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"plugins": [
		"@typescript-eslint",
		"only-warn",
		"prettier",
		"import"
	],
	"rules": {
		"no-restricted-imports": ["error", {
			"patterns": [
				{
					"group": [
						"**/tests/specs/gateway-pg/stripe/*",
						"**/tests/specs/gateway-pg/stripe/**"
					],
					"message": "Legacy re-export path. Import directly from tests/features/gateway-pg/specs/stripe/ instead. See docs/ARCHITECTURE.md §2."
				},
				{
					"group": [
						"**/tests/pages/gateway-pg/*",
						"**/tests/pages/gateway-pg/**"
					],
					"message": "Legacy re-export path. Import directly from tests/pages/carrier/ or tests/pages/shared/ instead. See docs/ARCHITECTURE.md §2."
				},
				{
					"group": [
						"**/tests/data/gateway-pg/*",
						"**/tests/data/gateway-pg/**"
					],
					"message": "Legacy re-export path. Import directly from tests/features/gateway-pg/data/ instead. See docs/ARCHITECTURE.md §2."
				},
				{
					"group": [
						"**/tests/pages/LoginPage"
					],
					"message": "Deprecated re-export. Import directly from tests/pages/shared/LoginPage instead. See docs/ARCHITECTURE.md §2."
				},
				{
					"group": [
						"**/tests/utils/apiClient"
					],
					"message": "Deprecated re-export. Import from the canonical location in tests/utils/ instead. See docs/ARCHITECTURE.md §2."
				}
			]
		}],
		"no-restricted-syntax": [
			"warn",
			{
				"selector": "Literal[value=/0025000031550*/]",
				"message": "Card 3155 (LEGACY_3DS_SUCCESS) is deprecated due to flakiness. Use CARDS.HAPPY_3DS (3184) instead. See tests/fixtures/stripe/card-policy.ts."
			},
			{
				"selector": "TemplateLiteral > TemplateElement[value.raw=/0025000031550*/]",
				"message": "Card 3155 (LEGACY_3DS_SUCCESS) is deprecated due to flakiness. Use CARDS.HAPPY_3DS (3184) instead. See tests/fixtures/stripe/card-policy.ts."
			},
			{
				"selector": "ImportSpecifier[imported.name='LEGACY_3DS_SUCCESS']",
				"message": "LEGACY_3DS_SUCCESS (card 3155) is deprecated. Prefer CARDS.HAPPY_3DS (3184). See tests/fixtures/stripe/card-policy.ts."
			},
			{
				"selector": "MemberExpression[object.name='CARDS'][property.name='LEGACY_3DS_SUCCESS']",
				"message": "CARDS.LEGACY_3DS_SUCCESS (card 3155) is deprecated. Use CARDS.HAPPY_3DS (3184) instead. See tests/fixtures/stripe/card-policy.ts."
			}
		],
		"@typescript-eslint/consistent-type-imports": "error",
		"@typescript-eslint/naming-convention": [
			"warn"
		],

		// 🔽 Desactivadas porque requieren type information
		"@typescript-eslint/no-floating-promises": "off",
		"@typescript-eslint/no-misused-promises": "off",
		"@typescript-eslint/no-unnecessary-condition": "off",
		"@typescript-eslint/no-unsafe-argument": "off",
		"@typescript-eslint/no-unsafe-assignment": "off",

		"arrow-spacing": [
			"warn",
			{
				"before": true,
				"after": true
			}
		],
		"brace-style": [
			"warn",
			"1tbs",
			{
				"allowSingleLine": true
			}
		],
		"curly": [
			"error",
			"multi-line"
		],
		"comma-dangle": [
			"warn",
			"never"
		],
		"eqeqeq": "warn",
		"import/namespace": "off",
		"import/no-duplicates": "off",
		"import/no-unresolved": [
			2,
			{
				"commonjs": true,
				"amd": false,
				"caseSensitive": true
			}
		],
		"indent": [
			"warn",
			"tab",
			{
				"SwitchCase": 1
			}
		],
		"linebreak-style": [
			"off"
		],
		"no-multi-spaces": [
			"warn"
		],
		"no-multiple-empty-lines": [
			"error",
			{
				"max": 1,
				"maxEOF": 0
			}
		],
		"object-curly-spacing": [
			"warn",
			"always"
		],
		"quotes": [
			"warn",
			"single"
		],
		"semi": [
			"warn"
		],
		"space-before-blocks": [
			"warn"
		],
		"space-before-function-paren": [
			"error",
			{
				"anonymous": "never",
				"named": "never",
				"asyncArrow": "always"
			}
		]
	},
	"overrides": [
		{
			"files": [
				"tests/**/*.ts"
			],
			"env": {
				"browser": true,
				"node": true
			}
		},
		{
			"files": [
				"tests/specs/gateway-pg/stripe/**/*.ts",
				"tests/pages/gateway-pg/**/*.ts",
				"tests/pages/gateway-pg/*.ts",
				"tests/data/gateway-pg/**/*.ts",
				"tests/data/gateway-pg/*.ts",
				"tests/pages/LoginPage.ts",
				"tests/utils/apiClient.ts"
			],
			"rules": {
				"no-restricted-imports": "off"
			}
		},
		{
			"files": [
				"tests/features/gateway-pg/data/stripe-cards.ts"
			],
			"rules": {
				"no-restricted-syntax": "off"
			}
		}
	],
	"settings": {
		"import/resolver": {
			"alias": {
				"map": [
					[
						"@pages",
						"./tests/pages"
					],
					[
						"@helper",
						"./tests/helper"
					],
					[
						"@data",
						"./tests/data"
					],
					[
						"@type",
						"./tests/interfaces"
					],
					[
						"@api",
						"./tests/apis"
					],
					[
						"@TestBase",
						"./tests/pages/TestBase.ts"
					],
					[
						"@playwrightConfig",
						"./playwright.config.ts"
					]
				],
				"extensions": [
					".ts",
					".js",
					".json"
				]
			}
		}
	}
}
